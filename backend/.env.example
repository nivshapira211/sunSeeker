# MongoDB: localhost:27017, database name posts-app (register/login and app data)
MONGO_URI=mongodb://localhost:27017/posts-app

# Auth (use strong secrets in production)
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
# Optional: access token TTL (default 1h). Examples: 15m, 1h, 7d
# JWT_ACCESS_EXPIRES_IN=1h

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for OAuth redirect and CORS)
CLIENT_URL=https://localhost:5173
CORS_ORIGIN=https://localhost:5173

# Optional: Google OAuth (for login with Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: AI service key (e.g. Gemini)
# AI_API_KEY=

# Optional: SSL cert paths (defaults to repo ssl/ folder)
# SSL_KEY_PATH=
# SSL_CERT_PATH=
