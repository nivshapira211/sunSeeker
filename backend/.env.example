# MongoDB: localhost:27017, database name posts-app (register/login and app data)
MONGO_URI=mongodb://localhost:27017/posts-app

# Auth (use strong secrets in production)
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
# Optional: access token TTL (default 1h). Examples: 15m, 1h, 7d
# JWT_ACCESS_EXPIRES_IN=1h

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for OAuth redirect and CORS)
CLIENT_URL=https://localhost:5173
CORS_ORIGIN=https://localhost:5173

# AI caption and recommendations (Gemini). Get a key at https://aistudio.google.com/apikey
# AI caption needs quota: free tier has limits; if you see "rate limit or quota" use a key with quota or enable billing.
# AI_API_KEY=your_gemini_api_key
# Optional: model override if default fails (e.g. gemini-1.5-flash or gemini-2.0-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Optional: Google OAuth (for login with Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: SSL cert paths (defaults to repo ssl/ folder)
# SSL_KEY_PATH=
# SSL_CERT_PATH=
