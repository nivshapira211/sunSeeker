NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/posts-app
JWT_SECRET=super_secret_jwt_key
JWT_REFRESH_SECRET=super_secret_refresh_key
# OpenRouter AI (recommendations, caption, assistant). Get key at https://openrouter.ai (key starts with sk-or-)
# Set this in your .env for AI features to work; do not commit the key.
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: model override (default openai/gpt-4o-mini for text and vision)
# OPENROUTER_MODEL=openai/gpt-4o-mini
SSL_KEY_PATH=../ssl/server.key
SSL_CERT_PATH=../ssl/server.crt
CORS_ORIGIN=https://localhost:5173
